              }
            }
          ],
          "setSystemVariable": true
        },
        "policy": {
          "secureInput": false,
          "secureOutput": false
        },
        "name": "Set return value - success",
        "dependsOn": [
          {
            "activity": "Transform Bronze to Silver",
